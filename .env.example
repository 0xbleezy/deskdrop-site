# Copy to .env.local and fill in.

# Resend API key for the contact form. Create at https://resend.com/api-keys
RESEND_API_KEY=

# Recipient address for contact-form submissions.
CONTACT_TO_EMAIL=eyn@thedeskdrop.com

# Sender address. Must be on a Resend-verified domain.
CONTACT_FROM_EMAIL=noreply@thedeskdrop.com
